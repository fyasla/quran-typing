{
  "name": "quran-typing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fetch-data": "node scripts/fetch-quran-data.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*\" \"scripts/**/*\" \"*.{ts,js,json,html}\"",
